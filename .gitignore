# Optimized .gitignore for C/CMake project (macOS + common editors)

# macOS
.DS_Store

# Editors and IDEs
.idea/
.vscode/
*.swp
*~
*.swo

# Xcode
xcuserdata/
*.xcworkspace
*.xcodeproj

# CMake / build artifacts
# Ignore build directories and common CMake outputs
build/
**/build/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
compile_commands.json

# Object files, libs, executables
*.o
*.obj
*.lo
*.a
*.la
*.so
*.dylib
*.dll
*.exe
*.out
programa_test

# Debug symbols
*.dSYM/
*.dSYM.zip

# Static analysis / coverage / logs
*.log
coverage/
*.gcda
*.gcno

# IDE/project-specific
*.user
*.iml

# Temporary files
*.tmp
*.temp
*.bak
*.orig

# Tags, caches
tags
.cache/
.DS_Store

# Optional: package managers and OS artifacts
node_modules/
*.zip

# Keep local build artifacts out of Git (explicit coreC/build ignores are redundant)
# If you need specific files from a build directory, remove the pattern above and list them explicitly.
coreC/build_ios/programa_test.app/Info.plist
coreC/build_sim_arm/programa_test.app/Info.plist
coreC/build_sim_x86/programa_test.app/Info.plist
coreC/build_xcf/headers/core_component.h
coreC/build_xcf/headers/module.modulemap
coreC/build_xcf/spm/Package.swift
coreC/build_xcf/spm/CoreC.xcframework/Info.plist
coreC/build_xcf/spm/CoreC.xcframework/ios-arm64/Headers/core_component.h
coreC/build_xcf/spm/CoreC.xcframework/ios-arm64/Headers/module.modulemap
coreC/build_xcf/spm/CoreC.xcframework/ios-arm64_x86_64-simulator/Headers/core_component.h
coreC/build_xcf/spm/CoreC.xcframework/ios-arm64_x86_64-simulator/Headers/module.modulemap
